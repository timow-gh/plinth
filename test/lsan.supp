# Suppress known leaks in third-party OpenGL/GLX stacks used by headless
# sanitizer tests.  The allocations are inside GLFW/Mesa/llvmpipe and are
# reported when tests repeatedly create and destroy hidden OpenGL contexts.
leak:extensionSupportedGLX
leak:opengl::PointDrawable::draw_index_buffer
leak:opengl::LineDrawable::draw_index_buffer
leak:opengl::MeshDrawable::draw
leak:opengl::Framebuffer::resolve_to
leak:ImGui_ImplOpenGL3_RenderDrawData
leak:opengl::PresentationPass::present
